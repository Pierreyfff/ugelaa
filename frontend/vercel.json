{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://ugelaa.onrender.com/api/$1" },
    { "source": "/python/(.*)", "destination": "https://ugelaa-python.onrender.com/$1" },
    { "source": "/uploads/(.*)", "destination": "https://ugelaa.onrender.com/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
