# Development: runs directly via Vite proxy (CORS enabled on backend)
# Production (Vercel): set to your Render backend URL, e.g. https://planillas-backend.onrender.com
VITE_API_URL=http://localhost:8080

# Development: uses Vite proxy (/python -> localhost:8081)
# Production (Vercel): set to your Render Python URL, e.g. https://planillas-python.onrender.com
VITE_PYTHON_URL=/python