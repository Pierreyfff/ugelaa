# ===========================
# SEGURIDAD - OWASP & ISO 27001
# ===========================

# Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# JWT - debe ser una cadena larga y segura (mínimo 32 caracteres)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars

# Seguridad - Rate Limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60

# Seguridad - CORS (lista de orígenes separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://planillas.vercel.app

# Entorno
ENV=development
DEBUG=false

# ===========================
# CUMPLIMIENTO ISO 27001
# ===========================

# Política de contraseñas
# - Longitud mínima: 8 caracteres
# - Requiere mayúsculas, minúsculas, números y caracteres especiales
# - Rotación recomendada cada 90 días

# Tokens JWT
# - Access token: 15 minutos
# - Refresh token: 7 días (rotación automática)
# - Algoritmo: HS256 con clave de 256 bits mínimo

# Cifrado
# - Contraseñas: bcrypt cost factor 12
# - Base de datos: TLS/SSL (sslmode=require)
# - Cookies: HttpOnly + Secure + SameSite=Strict

# Logging (ISO 27001 A.12.4)
# - Todos los accesos autenticados
# - Cambios en datos sensibles
# - Errores de seguridad
# - Retención de logs: 90 días

# Headers de seguridad
# - X-Content-Type-Options: nosniff
# - X-Frame-Options: DENY
# - X-XSS-Protection: 1; mode=block
# - Strict-Transport-Security: max-age=31536000
# - Content-Security-Policy: strict